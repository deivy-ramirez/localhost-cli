#!/usr/bin/env bash

set -euo pipefail

HOSTS_FILE="/etc/hosts"

flush_dns() {
  sudo dscacheutil -flushcache 2>/dev/null || true
  sudo killall -HUP mDNSResponder 2>/dev/null || true
}

add_host() {
  local domain="$1"
  local ip="$2"

  echo "Agregando entrada en /etc/hosts..."
  echo "$ip $domain" | sudo tee -a "$HOSTS_FILE" > /dev/null
}

remove_host() {
  local domain="$1"

  echo "Eliminando entrada de $domain..."
  sudo sed -i '' "/$domain/d" "$HOSTS_FILE"
}

open_browser() {
  local domain="$1"
  echo "Abriendo navegador..."
  open "https://$domain" 2>/dev/null || true
}

echo "======================================="
echo "           LOCALHOST TOOL              "
echo "======================================="
echo ""

# 🔹 Pedir datos
read -rp "Dominio: " DOMAIN
read -rp "IP: " IP

if [[ -z "$DOMAIN" || -z "$IP" ]]; then
  echo "Error: dominio e IP son obligatorios"
  exit 1
fi

echo ""
echo "Configurando entorno..."

add_host "$DOMAIN" "$IP"
flush_dns

echo ""
echo "✔ Dominio configurado:"
echo "   https://$DOMAIN"
echo ""

open_browser "$DOMAIN"

echo ""
echo "Puedes navegar normalmente en el navegador."
echo ""

# 🔹 Esperar al usuario
read -rp "Presiona ENTER cuando quieras revertir los cambios..."

echo ""
echo "Revirtiendo cambios..."

remove_host "$DOMAIN"
flush_dns

echo ""
echo "✔ Todo restaurado correctamente"
echo ""
